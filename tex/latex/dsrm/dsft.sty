\DeclareSymbolFont{mathds}{U}{dsrm}{m}{n}
\DeclareMathAlphabet{\mathds}{U}{dsrm}{m}{n}
\newcommand\dsone{\mathds{1}}
\newcommand\ind[1]{\mathds{1}_{#1}}
\let\oldstar\star
\let\star\relax
\let\oldsquare\square
\let\square\relax
\let\oldtriangle\triangle
\let\triangle\relax
\DeclareMathSymbol{\square}{\mathbin}{mathds}{"41}
\DeclareMathSymbol{\star}{\mathbin}{mathds}{"42}
\DeclareMathSymbol{\triangle}{\mathbin}{mathds}{"43}
\newcommand{\filledstar}[1]{%
    \ifcase#1\relax%
        \ensuremath{\mathds{B}}%
    \or\relax%
        \ensuremath{\mathds{D}}%
    \or\relax%
        \ensuremath{\mathds{E}}%
    \or\relax%
        \ensuremath{\mathds{F}}%
    \or\relax%
        \ensuremath{\mathds{G}}%
    \or\relax%
        \ensuremath{\mathds{H}}%
    \else%
        \hphantom{\ensuremath{\mathds{B}}}
    \fi%
}
